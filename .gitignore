# --- Build output ---
/bin/
/dist/
/mykeep
/mykeep.exe
*.exe

# --- Go ---
# Test binaries / coverage / profiles
*.test
*.out
coverage.txt
coverage.html
# go workspace files (local-only)
go.work
go.work.sum
# vendored deps (we use modules, not vendoring)
/vendor/

# --- mykeep runtime data (must never be committed) ---
# The encrypted store, config, lockfile, and atomic-write temp files.
*.db.enc
*.db.enc.lock
mykeep.config.json
.mykeep-*.tmp
# The knowledge base created beside a binary, or a data/ dir from MYKEEP_DATA_DIR.
mykeep_kb/
/data/
# Downloaded / converted embedding models (~100+ MB; fetched at first launch).
**/models/

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp
*~

# --- OS cruft ---
.DS_Store
Thumbs.db
